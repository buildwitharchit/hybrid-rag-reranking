# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by both docker-compose and python-dotenv.

# ── Required ──────────────────────────────────────────────────────────────────
# Your OpenRouter API key. Get one at https://openrouter.ai/keys
# This is the ONLY external paid service. All ML models run locally.
OPENROUTER_API_KEY=sk-or-your-key-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Path inside the container where runtime data is stored.
# Do not change this unless you know what you are doing.
STORE_PATH=./store
